{
  "name": "@dockforge/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "NODE_ENV=production node --import tsx dist/apps/api/src/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dockforge/db": "workspace:*",
    "@dockforge/docker-runtime": "workspace:*",
    "@dockforge/orchestrator": "workspace:*",
    "@dockforge/shared": "workspace:*",
    "@fastify/cors": "^11.0.1",
    "@fastify/sensible": "^6.0.3",
    "@fastify/websocket": "^11.2.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/ws": "^8.5.14"
  }
}
