# DockForge local defaults for both development and local production.
# Copy this file to .env at the repository root before running pnpm dev or pnpm start.

# Docker Engine connection fallback. These values seed the first-run install flow and are used
# only until Docker settings are saved in the app database.
# Keep DOCKER_HOST unset if you only want socket-based access.
DOCKER_HOST=unix:///var/run/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock

# API server port.
API_HOST=0.0.0.0
API_PORT=4000

# Web server bind host and port.
WEB_HOST=0.0.0.0
WEB_PORT=3000

# Browser-facing API base URL used by the Next.js app.
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Optional. Defaults to file:./packages/db/dev.db when omitted.
DATABASE_URL=file:./packages/db/dev.db
